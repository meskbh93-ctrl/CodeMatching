# ─── Server ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Coolify will set this automatically if you add a DB service)
DATABASE_URL=postgresql://user:password@localhost:5432/classi_match

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Secret for the data import endpoint (choose any random string)
IMPORT_SECRET=change-me-to-something-random

# Port (Coolify sets this automatically)
PORT=3000
